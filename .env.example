# Copia este archivo como .env y llena los valores reales
# NUNCA subas el archivo .env a GitHub

# Tu clave privada de MetaMask (sin el 0x al inicio)
PRIVATE_KEY=tu_clave_privada_aqui

# URL RPC de Alchemy para Base Sepolia
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/TU_API_KEY_AQUI

# API key de Basescan (para verificar contratos, opcional por ahora)
ETHERSCAN_API_KEY=tu_basescan_key_aqui
